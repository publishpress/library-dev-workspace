#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Ψεύτικο Πρόγραμμα"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Ένα ελάχιστο ψεύτικο πρόγραμμα WordPress που χρησιμοποιείται για να δοκιμάσει το publishpress/dev-workspace τοπικά."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Αυτή είναι η πρώτη δείγμα κείμενο για απλό gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Αυτή είναι η δεύτερη δείγμα κείμενο για απλό gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Αυτή είναι η τρίτη δείγμα κείμενο για απλό gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Αυτή η πρόταση εκτυπώνεται με gettext χρησιμοποιώντας άμεσο echo."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Αυτή η γραμμή χρησιμοποιεί esc_html_e ώστε να μην μπορεί να διαταραχθεί η διάταξη από επικίνδυνη μορφοποίηση."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Αυτή η τιμή χρησιμοποιεί esc_attr_e και ανήκει μέσα σε ένα HTML χαρακτηριστικό."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Αυτή η γραμμή χρησιμοποιεί esc_html__ και επιστρέφει μια τιμή αντί να την εκτυπώνει."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Αυτή η γραμμή χρησιμοποιεί esc_attr__ για κείμενο που αποθηκεύεται σε χαρακτηριστικό."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Υπάρχει %d στοιχείο σε αυτή τη δοκιμή πληθυντικού."
msgstr[1] "Υπάρχουν %d στοιχεία σε αυτή τη δοκιμή πληθυντικού."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Αυτή η πρόταση έχει μία θέση για μια λέξη: σήμερα λέμε %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Ονομάζουμε δύο πράγματα με την σειρά προέλευσης: πρώτα %1$s, μετά %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Η αργότερη ρήτρα αναφέρει το %2$s πριν από την πρώιμη ρήτρα που αναφέρει το %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Εάν σας αρέσει το %1$s, παρακαλώ αφήστε μας μια βαθμολογία %2$s. Ευχαριστώ!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Σχετικά με το %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Γνωρίστε τον %1$s από το %2$s στις %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Μετρήσαμε %1$d στοιχεία και ετικετοποιήσαμε την παρτίδα ως %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"Η πρώτη γραμμή ονομάζει %1$s,  \n"
"και η δεύτερη γραμμή ονομάζει %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Η ακέραια θέση σε αυτή τη δοκιμή διαβάζεται ακριβώς %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Τα αποσπάσματα μέσα σε μία συμβολοσειρά μπορούν να αναμειγνύουν απόστροφες και διπλά εισαγωγικά, όπως είναι «σύντομο» και \"εισαγωγμένο\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Αυτό το μήνυμα είναι χωρισμένο σε δύο γραμμές στο αρχείο πηγής.  \n"
"Παρακαλώ μεταφράστε το ως μία φυσική πρόταση, όχι δύο ξεχωριστές ετικέτες."

#: assets/main.js:9
msgid "Fake Plugin main script loaded."
msgstr "Ο κύριος σενάριο του ψεύτικου Plugin φορτώθηκε."

#: assets/main.js:10
msgid "Save changes from the main panel."
msgstr "Αποθηκεύστε τις αλλαγές από την κύρια панέλα."

#. translators: %d: number of items
#: assets/main.js:13
msgid "One item selected in the main view."
msgid_plural "%d items selected in the main view."
msgstr[0] "Ένα στοιχείο επιλέχθηκε στην κύρια προβολή."
msgstr[1] "%d στοιχεία επιλέχθηκαν στην κύρια προβολή."

#: assets/menu.js:9
msgid "Open the fake plugin menu."
msgstr "Ανοίξτε το μενού του ψεύτικου plugin."

#: assets/menu.js:10
msgid "Settings for the fake plugin."
msgstr "Ρυθμίσεις για το ψεύτικο plugin."

#: fake-plugin.php:47
msgctxt "Button label: start recording audio or video."
msgid "Record"
msgstr "Καταγραφή"

#: fake-plugin.php:52
msgctxt "Noun: a single audio or video recording you can play back."
msgid "Record"
msgstr "Καταγραφή"

#: fake-plugin.php:59
msgctxt "Button label: close the dialog without keeping changes."
msgid "Leave"
msgstr "Αφήστε"

#. translators: %s: number of messages
#: fake-plugin.php:80
#, php-format
msgctxt "Count of admin notices about translation tests."
msgid "You have %d message that needs gettext context."
msgid_plural "You have %d messages that need gettext context."
msgstr[0] "Έχετε %d μήνυμα που χρειάζεται συμφραζόμενα gettext."
msgstr[1] "Έχετε %d μηνύματα που χρειάζονται συμφραζόμενα gettext."

#: assets/main.js:11
msgctxt "Button label in main script"
msgid "Close"
msgstr "Κλείσιμο"

#: assets/menu.js:11
msgctxt "Admin sidebar navigation label"
msgid "Menu"
msgstr "Μενού"
