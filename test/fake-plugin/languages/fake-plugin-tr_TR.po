#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Sahte Eklenti"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "PublishPress/dev-workspace'ı yerel olarak test etmek için kullanılan minimal sahte WordPress eklentisi."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Bu, düz gettext için birinci örnek metindir."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Bu, düz gettext için ikinci örnek metindir."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Bu, düz gettext için üçüncü örnek metindir."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Bu cümle hemen echo ile gettext kullanılarak yazdırılır."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Bu satır, esc_html_e kullanarak güvenli olmayan işaretlemenin düzeni bozmasını engeller."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Bu değer, esc_attr_e kullanır ve bir HTML niteliği içinde yer alır."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Bu satır, echo etmek yerine bir değer döndürmek için esc_html__ kullanır."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Bu satır, bir niteliğinde saklanan metin için esc_attr__ kullanır."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Bu çoğul-form testinde %d öge var."
msgstr[1] "Bu çoğul-form testinde %d öge bulunmaktadır."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Bu cümlede bir kelime için bir yer var: bugün %s diyoruz."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Kaynak sırasındaki iki şeyi adlandırıyoruz: önce %1$s, sonra %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Sonraki cümle, daha önceki cümle %1$s'ı anmadan önce %2$s'ı bahsediyor."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Eğer %1$s'ı beğendiyseniz, lütfen bize bir %2$s puanı bırakın. Teşekkürler!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "%s hakkında"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "%1$s ile %2$s'ı %3$s'da buluşturun."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "%1$d öge saydık ve grubu %2$s olarak etiketledik."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"İlk satır %1$s adını belirtir,\n"
"ve ikinci satır %2$s adını belirtir."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Bu testteki tam sayı yer tutucusu tam olarak %d olarak okunur."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Bir dizedeki alıntılar tek tırnak ve çift tırnağı birleştirebilir, örneğin kısa ve \"alıntılanmış\" gibi."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Bu mesaj kaynak dosyasında iki satıra bölünmüştür.\n"
"Lütfen bunu iki ayrı etiket değil, tek bir doğal cümle olarak çevirin."

#: assets/main.js:9
msgid "Fake Plugin main script loaded."
msgstr "Sahte Eklenti ana betiği yüklendi."

#: assets/main.js:10
msgid "Save changes from the main panel."
msgstr "Ana panelden değişiklikleri kaydedin."

#. translators: %d: number of items
#: assets/main.js:13
msgid "One item selected in the main view."
msgid_plural "%d items selected in the main view."
msgstr[0] "Ana görünümde bir öğe seçildi.|"
msgstr[1] "Ana görünümde %d öğe seçildi."

#: assets/menu.js:9
msgid "Open the fake plugin menu."
msgstr "Sahte eklenti menüsünü açın."

#: assets/menu.js:10
msgid "Settings for the fake plugin."
msgstr "Sahte eklenti için ayarlar."

