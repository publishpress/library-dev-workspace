#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Dies ist die erste Beispielzeichenfolge für einfaches gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Dies ist die zweite Beispielzeichenfolge für einfaches gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Dies ist die dritte Beispielzeichenfolge für einfaches gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Dieser Satz wird mit gettext unter Verwendung von sofortigem Echo ausgegeben."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Diese Zeile verwendet esc_html_e, sodass unsichere Markups das Layout nicht brechen können."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Dieser Wert verwendet esc_attr_e und gehört in ein HTML-Attribut."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Diese Zeile verwendet esc_html__ und gibt einen Wert zurück, anstatt ihn auszugeben."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Diese Zeile verwendet esc_attr__ für Text, der in einem Attribut gespeichert ist."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Es gibt %d Element in diesem Pluralform-Test."
msgstr[1] "Es gibt %d Elemente in diesem Pluralform-Test."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Dieser Satz hat einen Platz für ein Wort: heute sagen wir %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Wir nennen zwei Dinge in der Quellreihenfolge: zuerst %1$s, dann %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Die spätere Klausel erwähnt %2$s vor der früheren Klausel, die %1$s erwähnt."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Wenn Ihnen %1$s gefällt, hinterlassen Sie uns bitte eine %2$s Bewertung. Vielen Dank!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Über %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Treffen Sie %1$s aus %2$s um %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Wir haben %1$d Elemente gezählt und die Charge als %2$s gekennzeichnet."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr "Die erste Zeile nennt %1$s, und die zweite Zeile nennt %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Der ganzzahlige Platzhalter in diesem Test lautet genau %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Anführungszeichen innerhalb eines Strings können Apostrophe und doppelte Anführungszeichen mischen, wie es's kurz und \"zitiert\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr "Diese Nachricht ist im Quelltext über zwei Zeilen verteilt. Bitte übersetzen Sie sie als einen natürlichen Satz, nicht als zwei separate Labels."

