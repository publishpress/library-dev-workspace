#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Plugin Falso"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Um plugin WordPress falso mínimo usado para testar publishpress/dev-workspace localmente."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Esta é a primeira string de exemplo para gettext simples."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Esta é a segunda string de exemplo para gettext simples."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Esta é a terceira string de exemplo para gettext simples."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Esta frase é impressa com gettext usando echo imediato."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Esta linha usa esc_html_e para que a marcação não segura não quebre o layout."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Este valor usa esc_attr_e e pertence a um atributo HTML."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Esta linha usa esc_html__ e retorna um valor em vez de o imprimir."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Esta linha usa esc_attr__ para texto armazenado em um atributo."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Há %d item neste teste de forma plural."
msgstr[1] "Há %d itens neste teste de forma plural."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Esta frase tem um espaço para uma palavra: hoje dizemos %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Nomeamos duas coisas na ordem de origem: primeiro %1$s, depois %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "A cláusula posterior menciona %2$s antes da cláusula anterior mencionar %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Se você gosta de %1$s, por favor, deixe-nos uma classificação de %2$s. Obrigado!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Sobre %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Conheça %1$s de %2$s às %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Contámos %1$d itens e rotulámos o lote como %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"A primeira linha nomeia %1$s,  \n"
"e a segunda linha nomeia %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "O espaço reservado inteiro nesta frase de teste é exatamente %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "As citações dentro de uma string podem misturar apóstrofes e aspas duplas, como é curto e \"cotado\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Esta mensagem está dividida em duas linhas no arquivo fonte.  \n"
"Por favor, traduza-a como uma frase natural, não duas etiquetas separadas."

