#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Falešný plugin"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Minimální falešný plugin pro WordPress, který se používá k testování publishpress/dev-workspace lokálně."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Toto je první ukázkový řetězec pro běžný gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Toto je druhý ukázkový řetězec pro běžný gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Toto je třetí ukázkový řetězec pro běžný gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Tato věta je vytištěna pomocí gettext s okamžitým echo."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Tento řádek používá esc_html_e, takže nebezpečný markup nemůže rozbít rozložení."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Tato hodnota používá esc_attr_e a patří dovnitř HTML atributu."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Tento řádek používá esc_html__ a vrací hodnotu místo jejího vytištění."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Tento řádek používá esc_attr__ pro text uložený v atributu."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "V této zkušební množině je %d položka."
msgstr[1] "V této zkušební množině jsou %d položky."
msgstr[2] "V této zkušební množině jsou %d položek."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Tato věta má jedno místo pro slovo: dnes říkáme %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Pojmenováváme dvě věci v pořadí zdroje: nejprve %1$s, pak %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Pozdější klauzule zmiňuje %2$s před tím, než dřívější klauzule zmiňuje %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Pokud se vám líbí %1$s, prosím, dejte nám hodnocení %2$s. Děkujeme!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "O %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Setkejte se s %1$s z %2$s v %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Spočítali jsme %1$d položek a označili dávku jako %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr "První řádek jmenuje %1$s, a druhý řádek jmenuje %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Celé číslo v této testovací větě zní přesně %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Citace uvnitř jednoho řetězce mohou míchat apostrofy a uvozovky, jako že to's krátké a \"citované\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr "Tato zpráva je rozdělena do dvou řádků v souboru se zdrojem. Prosím, přeložte to jako jednu přirozenou větu, ne jako dvě samostatné štítky."

#: assets/main.js:9
msgid "Fake Plugin main script loaded."
msgstr "Hlavní skript falešného pluginu byl načten."

#: assets/main.js:10
msgid "Save changes from the main panel."
msgstr "Uložit změny z hlavního panelu."

#. translators: %d: number of items
#: assets/main.js:13
msgid "One item selected in the main view."
msgid_plural "%d items selected in the main view."
msgstr[0] "Byla vybrána jedna položka v hlavním zobrazení."
msgstr[1] "%d položky byly vybrány v hlavním zobrazení."
msgstr[2] "%d položek bylo vybráno v hlavním zobrazení."

#: assets/menu.js:9
msgid "Open the fake plugin menu."
msgstr "Otevřete nabídku falešného pluginu."

#: assets/menu.js:10
msgid "Settings for the fake plugin."
msgstr "Nastavení pro falešný plugin."

