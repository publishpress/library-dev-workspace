#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Plugin Palsu"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Plugin WordPress palsu minimal yang digunakan untuk menguji publishpress/dev-workspace secara lokal."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Ini adalah contoh string pertama untuk gettext biasa."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Ini adalah contoh string kedua untuk gettext biasa."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Ini adalah contoh string ketiga untuk gettext biasa."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Kalimat ini dicetak dengan gettext menggunakan echo langsung."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Baris ini menggunakan esc_html_e sehingga markup yang tidak aman tidak dapat merusak tata letak."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Nilai ini menggunakan esc_attr_e dan berada di dalam atribut HTML."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Baris ini menggunakan esc_html__ dan mengembalikan nilai alih-alih mencetaknya."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Baris ini menggunakan esc_attr__ untuk teks yang disimpan dalam atribut."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Ada %d item dalam uji bentuk jamak ini."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Kalimat ini memiliki satu slot untuk sebuah kata: hari ini kami mengatakan %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Kami menyebutkan dua hal dalam urutan sumber: pertama %1$s, kemudian %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Klausul yang lebih belakangan menyebutkan %2$s sebelum klausul yang lebih awal menyebutkan %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Jika Anda menyukai %1$s, silakan tinggalkan kami penilaian %2$s. Terima kasih!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Tentang %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Temui %1$s dari %2$s di %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Kami menghitung %1$d item dan memberi label batch sebagai %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"Baris pertama menyebutkan %1$s,  \n"
"dan baris kedua menyebutkan %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Placeholder integer dalam tes ini dibaca tepat %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Kutipan di dalam satu string dapat mencampur apostrof dan kutipan ganda, seperti ini's pendek dan \"terkutip\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Pesan ini terbagi menjadi dua baris dalam file sumber.  \n"
"Silakan terjemahkan sebagai satu kalimat alami, bukan dua label terpisah."

