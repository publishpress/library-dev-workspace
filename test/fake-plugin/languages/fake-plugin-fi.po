#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Väärennetty liitännäinen"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Vähäinen väärä WordPress-laajennus, jota käytetään publishpress/dev-workspace -testauksen suorittamiseen paikallisesti."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Tämä on ensimmäinen esimerkkijono tavalliselle gettextille."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Tämä on toinen esimerkkijono tavalliselle gettextille."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Tämä on kolmas esimerkkijono tavalliselle gettextille."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Tämä lause tulostetaan gettextin avulla välittömällä echo:lla."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Tässä rivissä käytetään esc_html_e:tä, joten epävarma merkintä ei voi rikkoa ulkoasua."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Tässä arvossa käytetään esc_attr_e:tä ja se kuuluu HTML-attribuutin sisään."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Tässä rivissä käytetään esc_html__ ja se palauttaa arvon sen sijaan, että se tulostettaisiin."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Tässä rivissä käytetään esc_attr__:ta tekstille, joka on tallennettu attribuuttiin."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Testissä on %d kohde."
msgstr[1] "Testissä on %d kohdetta."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Tässä lauseessa on yksi paikka sanalle: tänään sanomme %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Nimeämme kaksi asiaa lähdejärjestyksessä: ensin %1$s, sitten %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Myöhempi lause mainitsee %2$s ennen kuin aikaisempi lause mainitsee %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Jos pidät %1$s:stä, jätä meille %2$s arvio. Kiitos!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Tietoja %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Tapaa %1$s paikasta %2$s aikaan %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Laskimme %1$d kohdetta ja merkkasimme erän %2$s:ksi."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"Ensimmäisellä rivillä on %1$s, \n"
"ja toisella rivillä on %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Kokonaisluku-paikka tässä testissä lukee tarkalleen %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Lainausmerkit yhdessä merkkijonossa voivat sekoittaa yksinkertaisia ja kaksinkertaisia lainausmerkkejä, kuten se's lyhyt ja \"lainattu\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Tämä viesti on jaettu kahdelle riville lähdetiedostossa. \n"
"Ole hyvä ja käännä se yhtenä luonnollisena lauseena, ei kahtena erillisenä nimilappuna."

#: assets/main.js:9
msgid "Fake Plugin main script loaded."
msgstr "Vale Pluginin pääskripti ladattu."

#: assets/main.js:10
msgid "Save changes from the main panel."
msgstr "Tallenna muutokset pääpaneelista."

#. translators: %d: number of items
#: assets/main.js:13
msgid "One item selected in the main view."
msgid_plural "%d items selected in the main view."
msgstr[0] "Yksi kohde valittu päänäkymässä."
msgstr[1] "%d kohdetta valittu päänäkymässä."

#: assets/menu.js:9
msgid "Open the fake plugin menu."
msgstr "Avaa vale pluginin valikko."

#: assets/menu.js:10
msgid "Settings for the fake plugin."
msgstr "Vale pluginin asetukset."

