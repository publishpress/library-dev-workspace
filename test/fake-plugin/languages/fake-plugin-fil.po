#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Isang minimal na pekeng WordPress plugin na ginamit upang subukan ang publishpress/dev-workspace nang lokal."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Ito ang unang halimbawa ng string para sa plain gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Ito ang pangalawang halimbawa ng string para sa plain gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Ito ang pangatlong halimbawa ng string para sa plain gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Ang pangungulong ito ay naka-print gamit ang gettext gamit ang agarang echo."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Ang linyang ito ay gumagamit ng esc_html_e kaya hindi ligtas na markup ay hindi makasasagabal sa layout."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Ang halagang ito ay gumagamit ng esc_attr_e at nabibilang sa loob ng isang HTML attribute."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Ang linyang ito ay gumagamit ng esc_html__ at nagbabalik ng halaga sa halip na i-echo ito."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Ang linyang ito ay gumagamit ng esc_attr__ para sa teksto na nakaimbak sa isang katangian."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "May %d item sa pagsubok na ito ng plural-form."
msgstr[1] "May %d items sa pagsubok na ito ng plural-form."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Ang pangungulong ito ay may isang puwang para sa isang salita: ngayon ay sinasabi namin %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Binanggit namin ang dalawang bagay sa pagkakasunud-sunod ng source: una %1$s, pagkatapos %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Ang huling bahagi ay binanggit ang %2$s bago ang naunang bahagi na binanggit ang %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Kung gusto mo ang %1$s, mangyaring iwanan kami ng %2$s na rating. Salamat!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Tungkol sa %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Kilala si %1$s mula sa %2$s sa %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Bumilang kami ng %1$d items at tinawag ang batch bilang %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr "Ang unang linya ay nagngangalang %1$s, at ang pangalawang linya ay nagngangalang %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Ang integer na placeholder sa test na ito ay nagbabasa ng eksaktong %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Ang mga quote sa loob ng isang string ay maaaring pagsamahin ang mga apostrophe at double quotes, tulad ng 'maikli' at \"nakak quote\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr "Ang mensaheng ito ay nahahati sa dalawang linya sa source file. Pakitranslate ito bilang isang natural na pangungusap, hindi dalawang hiwalay na label."

