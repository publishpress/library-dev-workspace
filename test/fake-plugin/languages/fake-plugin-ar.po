#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "برنامج وهمي"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "برنامج وهمي بسيط لـ WordPress يستخدم لاختبار publishpress/dev-workspace محليًا."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "هذه هي السلسلة التجريبية الأولى لـ gettext العادي."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "هذه هي السلسلة التجريبية الثانية لـ gettext العادي."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "هذه هي السلسلة التجريبية الثالثة لـ gettext العادي."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "تتم طباعة هذه الجملة باستخدام gettext مع الإخراج الفوري."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "تستخدم هذه السطر esc_html_e لذا لا يمكن أن تؤثر العلامات غير الآمنة على التصميم."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "تستخدم هذه القيمة esc_attr_e وتنتمي داخل سمة HTML."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "يستخدم هذا السطر esc_html__ ويعيد قيمة بدلاً من إخراجها."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "يستخدم هذا السطر esc_attr__ للنص المخزن في سمة."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "هناك %d عنصر في هذا الاختبار من صيغة الجمع."
msgstr[1] "هناك %d عنصرين في هذا الاختبار من صيغة الجمع."
msgstr[2] "هناك %d عناصر في هذا الاختبار من صيغة الجمع."
msgstr[3] "هناك %d عنصرين في هذا الاختبار من صيغة الجمع."
msgstr[4] "هناك %d عناصر في هذا الاختبار من صيغة الجمع."
msgstr[5] "هناك %d عنصر في هذا الاختبار من صيغة الجمع."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "تحتوي هذه الجملة على مكان واحد لكلمة: اليوم نقول %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "نذكر شيئان بترتيب المصدر: أولاً %1$s، ثم %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "يظهر العبارة اللاحقة %2$s قبل العبارة السابقة %1$s عن عمد."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "إذا أعجبتك %1$s، يرجى ترك تقييم لنا %2$s. شكرًا لك!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "حول %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "التقي بـ %1$s من %2$s في %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "قمنا بعدّ %1$d عنصرًا وأطلقنا على الدفعة اسم %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr "السطر الأول يسمي %1$s، والسطر الثاني يسمي %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "يقرأ عنصر النمط الصحيح في هذه العبارة الاختبارية بالضبط %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "يمكن أن تحتوي الاقتباسات داخل سلسلة واحدة على علامات اقتباس مفردة وعلامات اقتباس مزدوجة، مثل 'قصيرة و \"مقتبسة\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr "تم تقسيم هذه الرسالة عبر سطرين في ملف المصدر. يرجى ترجمتها كجملة طبيعية واحدة، وليس كعلامتين منفصلتين."

