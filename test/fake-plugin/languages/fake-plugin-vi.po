msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Một plugin WordPress giả tối giản được sử dụng để thử nghiệm publishpress/dev-workspace cục bộ."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Đây là chuỗi mẫu đầu tiên cho gettext đơn giản."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Đây là chuỗi mẫu thứ hai cho gettext đơn giản."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Đây là chuỗi mẫu thứ ba cho gettext đơn giản."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Câu này được in ra bằng gettext sử dụng echo ngay lập tức."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Dòng này sử dụng esc_html_e để đảm bảo mã không an toàn không thể phá vỡ bố cục."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Giá trị này sử dụng esc_attr_e và thuộc bên trong một thuộc tính HTML."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Dòng này sử dụng esc_html__ và trả về một giá trị thay vì in ra."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Dòng này sử dụng esc_attr__ cho văn bản được lưu trữ trong một thuộc tính."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Có %d mục trong bài kiểm tra dạng số nhiều này."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Câu này có một chỗ cho một từ: hôm nay chúng ta nói %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Chúng ta liệt kê hai thứ theo thứ tự nguồn: đầu tiên %1$s, sau đó %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Câu sau đề cập đến %2$s trước khi câu trước đề cập đến %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Nếu bạn thích %1$s, vui lòng để lại cho chúng tôi một đánh giá %2$s. Cảm ơn bạn!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Về %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Gặp gỡ %1$s từ %2$s vào lúc %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Chúng tôi đã đếm được %1$d mục và gán nhãn lô là %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"Dòng đầu tiên tên là %1$s,  \n"
"và dòng thứ hai tên là %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Chỗ dành cho số nguyên trong thử nghiệm này đọc chính xác là %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Trích dẫn bên trong một chuỗi có thể trộn lẫn giữa dấu nháy đơn và dấu nháy kép, như nó's ngắn và \"được trích dẫn\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Thông điệp này được chia thành hai dòng trong tệp nguồn.  \n"
"Vui lòng dịch nó như một câu tự nhiên, không phải hai nhãn riêng biệt."

