#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Een minimale nep WordPress-plugin die wordt gebruikt om publishpress/dev-workspace lokaal te testen."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Dit is de eerste voorbeeldstring voor gewone gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Dit is de tweede voorbeeldstring voor gewone gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Dit is de derde voorbeeldstring voor gewone gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Deze zin wordt afgedrukt met gettext met onmiddellijke echo."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Deze regel gebruikt esc_html_e zodat onveilige opmaak de lay-out niet kan breken."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Deze waarde gebruikt esc_attr_e en hoort binnen een HTML-attribuut."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Deze regel gebruikt esc_html__ en retourneert een waarde in plaats van deze te echoën."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Deze regel gebruikt esc_attr__ voor tekst die in een attribuut is opgeslagen."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Er is %d item in deze meervoudsvorm-test."
msgstr[1] "Er zijn %d items in deze meervoudsvorm-test."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Deze zin heeft één plaats voor een woord: vandaag zeggen we %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "We noemen twee dingen in de volgorde van de bron: eerst %1$s, dan %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "De latere clausule vermeldt %2$s voordat de eerdere clausule %1$s noemt."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Als je %1$s leuk vindt, laat ons dan alstublieft een %2$s beoordeling achter. Dank u!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Over %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Ontmoet %1$s uit %2$s om %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "We hebben %1$d items geteld en de batch gelabeld als %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr "De eerste regel noemt %1$s, en de tweede regel noemt %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "De gehele getalplaatsvervanger in deze test leest exact %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Citaattekens binnen één string kunnen apostrofs en dubbele aanhalingstekens mixen, zoals het's kort en \"geciteerd\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr "Dit bericht is verdeeld over twee regels in het brondocument. Vertaal het alstublieft als één natuurlijke zin, niet als twee aparte labels."

