#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Фейковый плагин"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Минимальный фейковый плагин WordPress, используемый для тестирования publishpress/dev-workspace локально."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Это первая примерная строка для простого gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Это вторая примерная строка для простого gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Это третья примерная строка для простого gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Это предложение выводится с помощью gettext с немедленным echo."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Эта строка использует esc_html_e, поэтому небезопасная разметка не может нарушить макет."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Это значение использует esc_attr_e и принадлежит внутри HTML-атрибута."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Эта строка использует esc_html__ и возвращает значение вместо его вывода."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Эта строка использует esc_attr__ для текста, хранящегося в атрибуте."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "В этом тесте с множественной формой %d элемент."
msgstr[1] "В этом тесте с множественной формой %d элемента."
msgstr[2] "В этом тесте с множественной формой %d элементов."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Это предложение имеет одно место для слова: сегодня мы говорим %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Мы называем две вещи в порядке источника: сначала %1$s, затем %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Позднее положение упоминает %2$s до того, как раннее положение упоминает %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Если вам нравится %1$s, пожалуйста, оставьте нам оценку в %2$s. Спасибо!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "О %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Встретьте %1$s из %2$s в %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Мы посчитали %1$d элементов и пометили партию как %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr "Первая строка называет %1$s, а вторая строка называет %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Целочисленный заполнитель в этом тесте читается как %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Цитаты внутри одной строки могут смешивать апострофы и двойные кавычки, как в том, что это коротко и \"цитируется\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr "Это сообщение разделено на две строки в исходном файле. Пожалуйста, переведите его как одно естественное предложение, а не как две отдельные метки."

