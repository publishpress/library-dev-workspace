#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Falsk plugin"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Et minimalt falsk WordPress-plugin, der bruges til at teste publishpress/dev-workspace lokalt."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Dette er den første prøve-streng til almindelig gettext."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Dette er den anden prøve-streng til almindelig gettext."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Dette er den tredje prøve-streng til almindelig gettext."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Denne sætning udskrives med gettext ved hjælp af øjeblikkelig echo."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Denne linje bruger esc_html_e, så usikker markup ikke kan bryde layoutet."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Denne værdi bruger esc_attr_e og tilhører inde i et HTML-attribut."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Denne linje bruger esc_html__ og returnerer en værdi i stedet for at ekko den."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Denne linje bruger esc_attr__ til tekst opbevaret i et attribut."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Der er %d element i denne plural-form test."
msgstr[1] "Der er %d elementer i denne plural-form test."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Denne sætning har et slot til et ord: i dag siger vi %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "Vi nævner to ting i kildeorden: først %1$s, derefter %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Den senere sætning nævner %2$s før den tidligere sætning nævner %1$s."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Hvis du kan lide %1$s, så giv os venligst en %2$s vurdering. Tak!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Om %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Mød %1$s fra %2$s kl. %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "Vi har talt %1$d elementer og mærket batchen som %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"Den første linje navngiver %1$s,  \n"
"og den anden linje navngiver %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Pladsholderen for heltal i denne test læser præcist %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Citeringer inden for én streng kan blande apostrofer og citationstegn, som f.eks. det's kort og \"citeret\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Denne besked er opdelt over to linjer i kildefilen.  \n"
"Venligst oversæt det som én naturlig sætning, ikke to separate etiketter."

