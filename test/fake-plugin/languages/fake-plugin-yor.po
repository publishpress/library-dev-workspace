#. Plugin Name of the plugin
#: fake-plugin.php:3
msgid "Fake Plugin"
msgstr "Fẹ́ẹ́kì Plugin"

#. Plugin URI of the plugin
#: fake-plugin.php:4
#, fuzzy
msgid "https://publishpress.com"
msgstr "https://publishpress.com"

#. Description of the plugin
#: fake-plugin.php:5
msgid "A minimal fake WordPress plugin used to test publishpress/dev-workspace locally."
msgstr "Plugin WordPress aláìlò tó pẹ́tẹ́lẹ̀ tí a lo láti ṣe àyẹ̀wò publishpress/dev-workspace níbi àgbègbè."

#. Author of the plugin
#: fake-plugin.php:7
#, fuzzy
msgid "PublishPress"
msgstr "PublishPress"

#: fake-plugin.php:25
msgid "This is the first sample string for plain gettext."
msgstr "Eyi ni àpẹẹrẹ àkọ́kọ́ fún gettext aláìlò."

#: fake-plugin.php:26
msgid "This is the second sample string for plain gettext."
msgstr "Eyi ni àpẹẹrẹ keji fún gettext aláìlò."

#: fake-plugin.php:27
msgid "This is the third sample string for plain gettext."
msgstr "Eyi ni àpẹẹrẹ kẹta fún gettext aláìlò."

#: fake-plugin.php:31
msgid "This sentence is printed with gettext using immediate echo."
msgstr "Gbolohun yìí ni a tẹ̀jáde pẹ̀lú gettext nípasẹ̀ echo lẹ́sẹkẹsẹ."

#: fake-plugin.php:35
msgid "This line uses esc_html_e so unsafe markup cannot break the layout."
msgstr "Ìlà yìí nlo esc_html_e nítorí pé a kò fẹ́ kí àpẹẹrẹ tó jẹ́ aláìlera ba àtúnṣe rẹ̀ kọ́."

#: fake-plugin.php:39
msgid "This value uses esc_attr_e and belongs inside an HTML attribute."
msgstr "Ìlà yìí nlo esc_attr_e àti pé ó jẹ́ ti àtẹ̀jáde HTML kan."

#: fake-plugin.php:43
msgid "This line uses esc_html__ and returns a value instead of echoing it."
msgstr "Ìlà yìí nlo esc_html__ àti pé ó padà wá iye kan dípò kí ó tẹ̀jáde rẹ."

#: fake-plugin.php:44
msgid "This line uses esc_attr__ for text stored in an attribute."
msgstr "Ìlà yìí nlo esc_attr__ fún ọrọ tó wa nínú àtẹ̀jáde."

#. translators: %d: number of items
#: fake-plugin.php:69
#, php-format
msgid "There is %d item in this plural-form test."
msgid_plural "There are %d items in this plural-form test."
msgstr[0] "Ó ní %d ohun kan nínú àdánwò fọọ́mù púpọ̀ yìí."

#. translators: %s: a short word inserted into the sentence
#: fake-plugin.php:92
#, php-format
msgid "This sentence has one slot for a word: today we say %s."
msgstr "Gbolohun yìí ní ibè kan fún ọrọ: lónìí a sọ %s."

#. translators: %1$s: earlier phrase, %2$s: later phrase (translators may reorder)
#: fake-plugin.php:98
#, php-format
msgid "We name two things in source order: first %1$s, then %2$s."
msgstr "A ń pe ohun méjì ní ìtòsọ́kan orísun: àkọ́kọ́ %1$s, lẹ́yìn náà %2$s."

#. translators: %1$s and %2$s appear out of numerical order on purpose
#: fake-plugin.php:105
#, php-format
msgid "The later clause mentions %2$s before the earlier clause mentions %1$s."
msgstr "Ìdí ni pé %2$s dúró níbẹ̀ kí %1$s tó dájú kí a mẹ́nu kàn."

#. translators: %1$s is the product name, %2$s is the star rating markup or label
#: fake-plugin.php:113
#, php-format
msgid "If you like %1$s, please leave us a %2$s rating. Thank you!"
msgstr "Tí o bá fẹ́ %1$s, jọ̀wọ́ fi %2$s àyẹ̀wò sílẹ̀ fún wa. Ẹ ṣéun!"

#. translators: %s: module title — control next to %1$s/%2$s strings (issue #81 compares these)
#: fake-plugin.php:120
#, php-format
msgid "About %s"
msgstr "Nípa %s"

#. translators: %1$s: name, %2$s: place, %3$s: time word (order may change per language)
#: fake-plugin.php:126
#, php-format
msgid "Meet %1$s from %2$s at %3$s."
msgstr "Pade %1$s láti %2$s ní %3$s."

#. translators: %1$d: count, %2$s: unit label
#: fake-plugin.php:134
#, php-format
msgid "We counted %1$d items and labeled the batch as %2$s."
msgstr "A ka %1$d ohun kan àti pé a dá àtẹ̀jáde náà sílẹ̀ gẹ́gẹ́ bí %2$s."

#. translators: Numbered placeholders split across a line break in the source (multiline msgid).
#: fake-plugin.php:141
#, php-format
msgid ""
"The first line names %1$s,\n"
"and the second line names %2$s."
msgstr ""
"Igbese akọkọ n pe %1$s,  \n"
"igbese keji n pe %2$s."

#. translators: %d: a whole number in a test phrase
#: fake-plugin.php:152
#, php-format
msgid "The integer placeholder in this test reads exactly %d."
msgstr "Iye ti o wa ninu idanwo yii kaakiri %d."

#: fake-plugin.php:158
msgid "Quotes inside one string can mix apostrophes and double quotes, like it's short and \"quoted\"."
msgstr "Awọn agbasọ inu okun kan le dapọ awọn apostrophes ati awọn agbasọ meji, gẹgẹ bi o ti jẹ kukuru ati \"quoted\"."

#: fake-plugin.php:164
msgid ""
"This message is split across two lines in the source file.\n"
"Please translate it as one natural sentence, not two separate labels."
msgstr ""
"Ifiranṣẹ yii pin ni awọn ila meji ninu faili orisun.  \n"
"Jọwọ tumọ rẹ gẹgẹ bi gbolohun kan ti o jẹ adayeba, kii ṣe awọn aami meji ti o yato."

#: assets/main.js:9
msgid "Fake Plugin main script loaded."
msgstr "Akọkọ iwe afọwọkọ ti Plugin irọ ti gbe wọle."

#: assets/main.js:10
msgid "Save changes from the main panel."
msgstr "Fipamọ awọn ayipada lati inu panẹli akọkọ."

#. translators: %d: number of items
#: assets/main.js:13
msgid "One item selected in the main view."
msgid_plural "%d items selected in the main view."
msgstr[0] "Ohun kan ti a yan ni iwo akọkọ."

#: assets/menu.js:9
msgid "Open the fake plugin menu."
msgstr "Ṣii akojọ aṣayan plugin irọ."

#: assets/menu.js:10
msgid "Settings for the fake plugin."
msgstr "Awọn eto fun plugin irọ."

#: fake-plugin.php:47
msgctxt "Button label: start recording audio or video."
msgid "Record"
msgstr "Iwe akọọlẹ"

#: fake-plugin.php:52
msgctxt "Noun: a single audio or video recording you can play back."
msgid "Record"
msgstr "Iwe akọọlẹ"

#: fake-plugin.php:59
msgctxt "Button label: close the dialog without keeping changes."
msgid "Leave"
msgstr "Fi silẹ"

#. translators: %s: number of messages
#: fake-plugin.php:80
#, php-format
msgctxt "Count of admin notices about translation tests."
msgid "You have %d message that needs gettext context."
msgid_plural "You have %d messages that need gettext context."
msgstr[0] "O ni %d ifiranṣẹ ti o nilo eto gettext."

#: assets/main.js:11
msgctxt "Button label in main script"
msgid "Close"
msgstr "Pa"

