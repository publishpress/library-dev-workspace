{
    "name": "publishpress/fake-plugin",
    "type": "wordpress-plugin",
    "version": "1.0.0",
    "description": "A fake WordPress plugin used to test publishpress/dev-workspace locally",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "plugin-name": "fake-plugin",
        "plugin-slug": "fake-plugin",
        "plugin-folder": "fake-plugin",
        "plugin-lang-domain": "fake-plugin",
        "plugin-github-repo": "publishpress/fake-plugin",
        "plugin-composer-package": "publishpress/fake-plugin"
    },
    "require-dev": {
        "publishpress/dev-workspace": "dev-development",
        "wp-coding-standards/wpcs": "^3"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "../.."
        }
    ],
    "config": {
        "allow-plugins": {
            "publishpress/dev-workspace": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
