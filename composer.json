{
    "name": "publishpress/dev-workspace",
    "type": "composer-plugin",
    "version": "1.2.2",
    "description": "Shared Composer scripts for PublishPress plugins",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "PublishPress\\DevWorkspace\\": "src/"
        }
    },
    "extra": {
        "class": "PublishPress\\DevWorkspace\\Plugin"
    },
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "composer-plugin-api": "^2.0",
        "automattic/vipwpcs": "^3",
        "behat/behat": "^3.14",
        "codeception/module-asserts": "^3",
        "codeception/module-cli": "^2",
        "codeception/module-db": "^3",
        "codeception/module-filesystem": "^3",
        "codeception/module-phpbrowser": "^3",
        "codeception/module-rest": "^3",
        "codeception/module-webdriver": "^3",
        "codeception/util-universalframework": "^1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1",
        "friendsofphp/php-cs-fixer": "^3.49",
        "knplabs/github-api": "^3.16",
        "lucatume/wp-browser": "^4",
        "nyholm/psr7": "^1.8",
        "overtrue/phplint": "^9.1",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpmd/phpmd": "^2.15",
        "phpmetrics/phpmetrics": "^2.9",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10",
        "publishpress/publishpress-phpcs-standards": "^1",
        "publishpress/translations": "dev-andergmartins/translations-auditor",
        "spatie/ray": "^1.41",
        "squizlabs/php_codesniffer": "^3.8",
        "symfony/http-client": "^7.1",
        "symfony/process": "^6.4",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-cli/i18n-command": "^2.6",
        "wp-cli/wp-cli-bundle": "^2.10",
        "wp-coding-standards/wpcs": "^3"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "dev:shell": "vendor/publishpress/dev-workspace/scripts/run.sh",
        "dev:shell:stop": "vendor/publishpress/dev-workspace/scripts/stop.sh",
        "not-container": "vendor/publishpress/dev-workspace/scripts/ensure-not-container.sh",
        "build": "@pack:zip",
        "build:all": [
            "@build:js",
            "@translate:compile",
            "@pack:zip"
        ],
        "pack:zip": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/pack.sh zip",
        "pack:zip:with-debug": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/pack.sh zip --with-debug",
        "pack:dir": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/pack.sh dir",
        "pack:dir:with-debug": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/pack.sh dir --with-debug",
        "pack:clean": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/pack.sh clean",
        "build:js-prod": "vendor/publishpress/dev-workspace/scripts/run.sh cross-env NODE_ENV=production npx webpack --progress",
        "build:js-dev": "vendor/publishpress/dev-workspace/scripts/run.sh cross-env NODE_ENV=development npx webpack --progress",
        "build:js": [
            "@build:js-prod",
            "@build:js-dev"
        ],
        "profile:js": "vendor/publishpress/dev-workspace/scripts/run.sh cross-env NODE_ENV=production npx webpack --profile",
        "watch:js": "vendor/publishpress/dev-workspace/scripts/run.sh cross-env NODE_ENV=development npx webpack --watch --progress",
        "check:all": [
            "@check:php",
            "@lint:php",
            "@lint:phpcs",
            "@check:longpath"
        ],
        "check:php": [
            "@check:php-5.6",
            "@check:php-7.2",
            "@check:php-7.4",
            "@check:php-8.0",
            "@check:php-8.1",
            "@check:php-8.2",
            "@check:php-8.3",
            "@check:php-8.4",
            "@check:php-8.5"
        ],
        "check:php-5.6": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 5.6 ./${PP_PLUGIN_SLUG}.php",
        "check:php-7.2": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 7.2 ./${PP_PLUGIN_SLUG}.php",
        "check:php-7.4": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 7.4",
        "check:php-8.0": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.0",
        "check:php-8.1": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.1",
        "check:php-8.2": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.2",
        "check:php-8.3": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.3",
        "check:php-8.4": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.4",
        "check:php-8.5": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.5",
        "lint:php": "vendor/publishpress/dev-workspace/scripts/run.sh phplint --no-cache",
        "check:deps": "vendor/publishpress/dev-workspace/scripts/run.sh php vendor/publishpress/dev-workspace/scripts/check-dependencies.php ./lib ${PP_PLUGIN_COMPOSER_PACKAGE}",
        "check:longpath": [
            "vendor/publishpress/dev-workspace/scripts/run.sh composer pack:dir",
            "vendor/publishpress/dev-workspace/scripts/run.sh longpath dist/${PP_PLUGIN_FOLDER}"
        ],
        "lint:phpcs": "vendor/publishpress/dev-workspace/scripts/run.sh phpcs",
        "qa:phpstan": "vendor/publishpress/dev-workspace/scripts/run.sh phpstan",
        "fix:cs": [
            "vendor/publishpress/dev-workspace/scripts/run.sh php-cs-fixer fix .",
            "vendor/publishpress/dev-workspace/scripts/run.sh phpcbf --standard=.phpcs.xml"
        ],
        "fix:deps": "vendor/publishpress/dev-workspace/scripts/run.sh php vendor/publishpress/dev-workspace/scripts/merge-dependencies.sh ./lib ${PP_PLUGIN_COMPOSER_PACKAGE}",
        "metrics": "vendor/publishpress/dev-workspace/scripts/run.sh phpmetrics --report-html=metrics --exclude=vendor,lib/vendor,tests,dist,.claude,.cursor,.github,.wordpress-org,.git,.zed,docs,languages.",
        "sync:local": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/local-sync.sh --watch"
        ],
        "sync:local:once": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/local-sync.sh"
        ],
        "sync:local:stop": [
            "@not-container",
            "pkill -f local-sync.sh || true"
        ],
        "sync:remote": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/sync-plugin-remote.sh --watch"
        ],
        "sync:remote:once": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/sync-plugin-remote.sh --once"
        ],
        "sync:remote:stop": [
            "@not-container",
            "pkill -f sync-plugin-remote.sh || true"
        ],
        "test": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/tests-run.sh $@"
        ],
        "test:up": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh up test",
            "@test:info"
        ],
        "test:driver": [
            "@not-container",
            "source ./.env && $CHROMEDRIVER_BINARY --port=$CHROMEDRIVER_PORT"
        ],
        "test:down": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh down test"
        ],
        "test:restart": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh restart test"
        ],
        "test:stop": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh stop test"
        ],
        "test:logs": [
            "@not-container",
            "bash -c 'cd vendor/publishpress/dev-workspace && set -a && source ../../../.env && set +a && docker compose -f docker/compose.yaml --profile test logs --tail=500'"
        ],
        "test:clean": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh cleanup test",
            "@test:clean-cache",
            "composer codecept clean"
        ],
        "test:clean-logs": [
            "@not-container",
            "rm -f dev-workspace-cache/logs/db_test/"
        ],
        "test:clean-cache": [
            "@not-container",
            "rm -rf dev-workspace-cache/wp_test",
            "rm -rf dev-workspace-cache/db_test"
        ],
        "test:db-export": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/tests-db-export.sh $@"
        ],
        "test:db-import": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/tests-db-import.sh $@"
        ],
        "test:db-logs": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/tests-db-logs.sh $@"
        ],
        "test:info": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh info test"
        ],
        "test:refresh": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/server.sh refresh test"
        ],
        "test:snippets": [
            "@not-container",
            "composer codecept gherkin:snippets $@"
        ],
        "test:steps": [
            "@not-container",
            "composer codecept gherkin:steps $@"
        ],
        "test:coverage": [
            "@not-container",
            "vendor/bin/codecept run --coverage --coverage-html $@"
        ],
        "test:debug": [
            "@not-container",
            "php -d xdebug.mode=debug -d xdebug.start_with_request=yes vendor/bin/codecept run $@"
        ],
        "codecept": [
            "@not-container",
            "./vendor/bin/codecept $@"
        ],
        "docker:cleanup": [
            "@not-container",
            "docker system prune -f"
        ],
        "info:versions": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/dependency-versions.sh",
        "set:version": "vendor/publishpress/dev-workspace/scripts/run.sh php vendor/publishpress/dev-workspace/scripts/plugin-bump-version.php \"$@\"",
        "pre-release": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/pre-release.sh \"$@\"",
            "@translate:audit"
        ],
        "pr-link": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/pr-link.sh"
        ],
        "deploy": "vendor/publishpress/dev-workspace/scripts/run.sh node vendor/publishpress/dev-workspace/scripts/custom-deploy/index.mjs",
        "after-pr-merge": [
            "@not-container",
            "vendor/publishpress/dev-workspace/scripts/after-pr-merge.sh"
        ],
        "translate": [
            "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/translate-locales.sh",
            "@translate:compile",
            "@translate:audit"
        ],
        "translate:check": "vendor/publishpress/dev-workspace/scripts/run.sh wp i18n audit ./languages --allow-root",
        "translate:audit": [
            "@translate:check",
            "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --audit --audit-mode=interactive"
        ],
        "translate:audit-report": [
            "@translate:check",
            "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --audit --audit-mode=report --audit-report-format=html,ansi"
        ],
        "translate:audit-view-report": [
            "vendor/publishpress/dev-workspace/scripts/run.sh more translation-audit-report.ansi.txt"
        ],
        "translate:dry-run": [
            "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --dry-run",
            "@translate:audit"
        ],
        "translate:download": [
            "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --download",
            "@translate:audit"
        ],
        "translate:upload": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --upload",
        "translate:custom": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --languages",
        "translate:force": [
            "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --force",
            "@translate:audit"
        ],
        "translate:force-custom": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --force --languages",
        "translate:compile": [
            "@translate:mo",
            "@translate:json",
            "@translate:php",
            "@translate:audit"
        ],
        "translate:pot": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/translate-pot.sh",
        "translate:mo": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/translate-mo.sh",
        "translate:json": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/translate-json.sh",
        "translate:php": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/publishpress/dev-workspace/scripts/translate-php.sh",
        "translate:cleanup": "rm languages/*.json languages/*.mo languages/*.php",
        "translate:repair": "vendor/publishpress/dev-workspace/scripts/run.sh vendor/bin/publishpress-translate --repair-plurals",
        "config:phpcs": "vendor/bin/phpcs --config-set installed_paths \"../../phpcsstandards/phpcsutils,../../phpcsstandards/phpcsextra,../../automattic/vipwpcs,../../phpcompatibility/php-compatibility,../../sirbrillig/phpcs-variable-analysis,../../publishpress/publishpress-phpcs-standards/standards,../../wp-coding-standards/wpcs\"",
        "post-install-cmd": [
            "@config:phpcs",
            "[ -f vendor/publishpress/translations/potomatic/potomatic.js ] && chmod +x vendor/publishpress/translations/potomatic/potomatic.js || true",
            "chmod +x vendor/publishpress/dev-workspace/scripts/*.sh || true"
        ],
        "post-update-cmd": [
            "@config:phpcs",
            "[ -f vendor/publishpress/translations/potomatic/potomatic.js ] && chmod +x vendor/publishpress/translations/potomatic/potomatic.js || true",
            "chmod +x vendor/publishpress/dev-workspace/scripts/*.sh || true"
        ],
        "pre-autoload-dump": "[ -f lib/composer.json ] && composer dumpautoload --working-dir=./lib || true",
        "pre-update-cmd": "[ -f lib/composer.json ] && composer update --working-dir=./lib || true",
        "pre-install-cmd": "[ -f lib/composer.json ] && composer install --working-dir=./lib || true"
    },
    "scripts-descriptions": {
        "dev:shell": "Run a command inside the dev-workspace container or open a new terminal",
        "dev:shell:stop": "Stop spawned dev shell processes",
        "build": "Create the distributable zip package",
        "build:all": "Build JavaScript, compile translations, then pack the plugin (zip) and build an unpacked plugin directory under dist",
        "pack:zip": "Create the distributable zip package",
        "pack:zip:with-debug": "Create the distributable zip package with debug assets",
        "pack:dir": "Build an unpacked plugin directory under dist",
        "pack:dir:with-debug": "Build an unpacked plugin directory under dist with debug assets",
        "pack:clean": "Clean build output from the packaging step",
        "build:js-prod": "Build JavaScript assets for production",
        "build:js-dev": "Build JavaScript assets for development",
        "build:js": "Build JavaScript for production and development",
        "profile:js": "Profile the JavaScript webpack build",
        "watch:js": "Watch JavaScript sources and rebuild on change",
        "check:all": "Run PHP compatibility, phplint, PHPCS, and long-path checks",
        "check:php": "Run PHP compatibility checks for all configured PHP versions",
        "check:php-5.6": "Check PHP 5.6 compatibility (main plugin file only)",
        "check:php-7.2": "Check PHP 7.2 compatibility (main plugin file only)",
        "check:php-7.4": "Check PHP 7.4 compatibility",
        "check:php-8.0": "Check PHP 8.0 compatibility",
        "check:php-8.1": "Check PHP 8.1 compatibility",
        "check:php-8.2": "Check PHP 8.2 compatibility",
        "check:php-8.3": "Check PHP 8.3 compatibility",
        "check:php-8.4": "Check PHP 8.4 compatibility",
        "check:php-8.5": "Check PHP 8.5 compatibility",
        "lint:php": "Lint PHP syntax with phplint",
        "lint:phpcs": "Check PHP coding standards with PHPCS",
        "qa:phpstan": "Run PHPStan static analysis",
        "check:deps": "Verify lib Composer dependencies against the free plugin package",
        "check:longpath": "Pack an unpacked build and scan for Windows long-path issues",
        "fix:cs": "Auto-fix coding standards (PHP-CS-Fixer and PHPCBF)",
        "fix:deps": "Merge free-plugin lib dependencies into lib/composer.json",
        "metrics": "Generate a PHPMetrics HTML report",
        "sync:local": "Watch and rsync the plugin to a local WordPress site",
        "sync:local:once": "Rsync the plugin once to a local WordPress site",
        "sync:local:stop": "Stop the local file watcher sync process",
        "sync:remote": "Watch and sync the plugin to a remote dev site",
        "sync:remote:once": "Sync the plugin once to a remote dev site",
        "sync:remote:stop": "Stop the remote sync watcher process",
        "test": "Run Codeception tests (pass suite or options as arguments)",
        "test:up": "Start the Docker-based test environment",
        "test:down": "Stop and remove the test environment containers",
        "test:restart": "Restart the test environment",
        "test:stop": "Stop the test environment without removing containers",
        "test:logs": "Tail Docker logs for the test profile",
        "test:clean": "Clean the test environment, caches, and Codeception output",
        "test:clean-cache": "Remove test WordPress and database cache directories",
        "test:clean-logs": "Remove test database log files",
        "test:db-export": "Export the test database to SQL",
        "test:db-import": "Import SQL into the test database",
        "test:db-logs": "Show test database container logs",
        "test:info": "Show URLs and ports for the test environment",
        "test:refresh": "Refresh the test environment (reinstall / reset as configured)",
        "test:driver": "Start ChromeDriver for browser tests",
        "test:snippets": "List missing Gherkin step snippets",
        "test:steps": "List registered Gherkin step definitions",
        "test:coverage": "Run Codeception with HTML coverage output",
        "test:debug": "Run Codeception with Xdebug enabled",
        "codecept": "Run Codeception CLI (pass codecept arguments)",
        "docker:cleanup": "Prune unused Docker data",
        "info:versions": "Print versions of main dev tools",
        "set:version": "Bump the plugin version in project files",
        "pre-release": "Prepare a release branch and open a pull request",
        "pr-link": "Print the release PR URL for the current branch",
        "deploy": "Run the interactive deployment helper",
        "after-pr-merge": "Run repository post-merge housekeeping",
        "translate": "Run PublishPress Translate for the default language set",
        "translate:dry-run": "PublishPress Translate dry run",
        "translate:download": "Download translations via PublishPress Translate",
        "translate:upload": "Upload translations via PublishPress Translate",
        "translate:custom": "PublishPress Translate with a custom language list",
        "translate:force": "PublishPress Translate with force overwrite",
        "translate:force-custom": "PublishPress Translate force mode for custom languages",
        "translate:compile": "Compile MO, JSON, and PHP translation files",
        "translate:pot": "Generate the POT file from PHP and JSX sources",
        "translate:mo": "Generate MO files from PO files",
        "translate:json": "Generate JSON translation files for JavaScript",
        "translate:php": "Generate PHP translation files for WordPress 6.5+",
        "config:phpcs": "Configure PHPCS installed_paths for this project",
        "post-install-cmd": "After install: configure PHPCS paths and fix potomatic permissions",
        "post-update-cmd": "After update: configure PHPCS paths and fix potomatic permissions",
        "pre-autoload-dump": "Dump lib autoload when lib/composer.json exists",
        "pre-update-cmd": "Update lib dependencies before the root update",
        "pre-install-cmd": "Install lib dependencies before the root install"
    }
}
